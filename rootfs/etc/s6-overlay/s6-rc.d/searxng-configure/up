#!/usr/bin/env sh

: ${CATEGORIES}
: ${DEFAULT_ENGINES}
: ${ENABLE_METRICS}
: ${IS_PUBLIC_INSTANCE}
: ${SECRET_KEY}

yq -i ".server.secret_key = env(SECRET_KEY)" /etc/searxng/settings.yml

unset SECRET_KEY

yq -i ".plugins[].active = false" /usr/local/searxng/searx/settings.yml

if [ ! -z "$CATEGORIES" ]; then
    yq -i '.categories_as_tabs = {}
        | (
            strenv(CATEGORIES)
            | split(",")
            | map(trim)
        ) as $x
        | .categories_as_tabs[$x[]] = ~
    ' /etc/searxng/settings.yml
else
    yq -i 'del(.categories_as_tabs)' /etc/searxng/settings.yml
fi

if [ ! -z "$DEFAULT_ENGINES" ]; then
    yq -i ".engines[].disabled = true" /usr/local/searxng/searx/settings.yml

    yq -i '.engines += (
        strenv(DEFAULT_ENGINES)
        | split(",")
        | map(trim)
        | map({
            "name": .,
            "disabled": false
        })
    )' /etc/searxng/settings.yml
else
    yq -i 'del(.engines)' /etc/searxng/settings.yml
fi

yq -i ".general.enable_metrics = env(ENABLE_METRICS)" /etc/searxng/settings.yml
yq -i ".server.public_instance = env(IS_PUBLIC_INSTANCE)" /etc/searxng/settings.yml

cp /usr/local/searxng/searx/limiter.toml /etc/searxng/limiter.toml
